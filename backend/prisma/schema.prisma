datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String           @id @default(uuid())
  organisationId String?
  organisation Organisation?    @relation(fields: [organisationId], references: [id])
  email        String           @unique
  name         String
  passwordHash String
  role         String           @default("OWNER")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  projects     MappingProject[]
  mappingEvents MappingEvent[]

  @@index([organisationId])
}

model System {
  id             String           @id @default(uuid())
  name           String
  type           String
  createdAt      DateTime         @default(now())
  entities       Entity[]
  sourceProjects MappingProject[] @relation("SourceSystem")
  targetProjects MappingProject[] @relation("TargetSystem")
}

model Entity {
  id                   String          @id @default(uuid())
  systemId             String
  system               System          @relation(fields: [systemId], references: [id], onDelete: Cascade)
  name                 String
  label                String?
  description          String?
  createdAt            DateTime        @default(now())
  fields               Field[]
  sourceEntityMappings EntityMapping[] @relation("SourceEntity")
  targetEntityMappings EntityMapping[] @relation("TargetEntity")

  @@index([systemId])
}

model Field {
  id                   String         @id @default(uuid())
  entityId             String
  entity               Entity         @relation(fields: [entityId], references: [id], onDelete: Cascade)
  name                 String
  label                String?
  dataType             String
  length               Int?
  precision            Int?
  scale                Int?
  required             Boolean        @default(false)
  isKey                Boolean        @default(false)
  isExternalId         Boolean        @default(false)
  picklistValues       String[]       @default([])
  validationRules      Json?
  // Connector metadata — persisted from jack henry / sap / salesforce connector fields
  jxchangeXPath        String?        // e.g. "CIFInq.Rs.CIFRec.CIFInfo.TaxId"
  jxchangeXtendElemKey String?        // Core Director XtendElem override key
  iso20022Name         String?        // ISO 20022 canonical name e.g. "TaxIdentification"
  complianceTags       String[]       @default([]) // e.g. ["GLBA_NPI","BSA_AML"]
  complianceNote       String?        // human-readable compliance caveat
  createdAt            DateTime       @default(now())
  canonicalMappings    FieldCanonicalMap[]
  sourceFieldMappings  FieldMapping[] @relation("SourceField")
  targetFieldMappings  FieldMapping[] @relation("TargetField")

  @@index([entityId])
}

model Relationship {
  id           String   @id @default(uuid())
  fromEntityId String
  toEntityId   String
  type         String
  viaField     String?
  createdAt    DateTime @default(now())

  @@index([fromEntityId])
}

model MappingProject {
  id             String          @id @default(uuid())
  organisationId String?
  organisation   Organisation?   @relation(fields: [organisationId], references: [id])
  name           String
  archived       Boolean         @default(false)
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceSystemId String
  targetSystemId String
  sourceSystem   System          @relation("SourceSystem", fields: [sourceSystemId], references: [id])
  targetSystem   System          @relation("TargetSystem", fields: [targetSystemId], references: [id])
  resolvedOneToManyMappings Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  entityMappings EntityMapping[]
  mappingEvents  MappingEvent[]
  auditEntries   AuditEntry[]
  exportVersions ExportVersion[]

  @@index([organisationId])
  @@index([userId])
}

model ExportVersion {
  id                String         @id @default(uuid())
  projectId         String
  project           MappingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version           Int
  schemaFingerprint Json
  fieldsSnapshot    Json?
  exportedAt        DateTime       @default(now())
  exportedByUserId  String?

  @@index([projectId, exportedAt])
}

model AuditEntry {
  id          String   @id @default(uuid())
  projectId   String
  project     MappingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actorUserId String
  actorEmail  String
  actorRole   String
  action      String
  targetType  String
  targetId    String
  diffBefore  Json?
  diffAfter   Json?
  timestamp   DateTime @default(now())

  @@index([projectId, timestamp])
  @@index([actorUserId])
}

model EntityMapping {
  id             String         @id @default(uuid())
  projectId      String
  project        MappingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceEntityId String
  sourceEntity   Entity         @relation("SourceEntity", fields: [sourceEntityId], references: [id])
  targetEntityId String
  targetEntity   Entity         @relation("TargetEntity", fields: [targetEntityId], references: [id])
  confidence     Float
  rationale      String
  createdAt      DateTime       @default(now())
  fieldMappings  FieldMapping[]

  @@index([projectId])
}

model FieldMapping {
  id              String        @id @default(uuid())
  entityMappingId String
  entityMapping   EntityMapping @relation(fields: [entityMappingId], references: [id], onDelete: Cascade)
  sourceFieldId   String
  sourceField     Field         @relation("SourceField", fields: [sourceFieldId], references: [id])
  targetFieldId   String
  targetField     Field         @relation("TargetField", fields: [targetFieldId], references: [id])
  transform       Json
  confidence      Float
  rationale       String
  status          String        @default("suggested")
  seedSource      String?
  retrievalShortlist Json?
  rerankerDecision Json?
  optimizerDisplacement Json?
  lowConfidenceFallback Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  mappingEvents   MappingEvent[]

  @@index([entityMappingId])
}

model Organisation {
  id             String          @id @default(uuid())
  slug           String          @unique
  name           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  users          User[]
  projects       MappingProject[]
  derivedMappings DerivedMapping[]
  mappingEvents  MappingEvent[]
}

model CanonicalDomain {
  id            String           @id @default(uuid())
  name          String           @unique
  description   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  canonicalFields CanonicalField[]
}

model CanonicalField {
  id             String           @id @default(uuid())
  domainId       String
  domain         CanonicalDomain  @relation(fields: [domainId], references: [id], onDelete: Cascade)
  conceptName    String
  displayLabel   String
  dataType       String
  complianceTags String[]         @default([])
  isDeprecated   Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  fieldMappings  FieldCanonicalMap[]
  derivedMappings DerivedMapping[]

  @@unique([domainId, conceptName])
  @@index([domainId])
}

model FieldCanonicalMap {
  id               String         @id @default(uuid())
  fieldId          String
  field            Field          @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  canonicalFieldId String
  canonicalField   CanonicalField @relation(fields: [canonicalFieldId], references: [id], onDelete: Cascade)
  confidence       Float          @default(1.0)
  mappedBy         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([fieldId, canonicalFieldId])
  @@index([canonicalFieldId])
}

model DerivedMapping {
  id               String          @id @default(uuid())
  organisationId   String
  organisation     Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  sourceSystemId   String
  sourceEntityName String
  sourceFieldName  String
  targetSystemId   String
  targetEntityName String
  targetFieldName  String
  canonicalFieldId String?
  canonicalField   CanonicalField? @relation(fields: [canonicalFieldId], references: [id], onDelete: SetNull)
  preferredTransform String?
  confidence       Float           @default(0)
  acceptCount      Int             @default(0)
  rejectCount      Int             @default(0)
  lastAcceptedAt   DateTime?
  lastRejectedAt   DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([organisationId, sourceSystemId, sourceEntityName, sourceFieldName, targetSystemId, targetEntityName, targetFieldName])
  @@index([organisationId, confidence])
}

model MappingEvent {
  id               String          @id @default(uuid())
  organisationId   String
  organisation     Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  projectId        String?
  project          MappingProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  fieldMappingId   String?
  fieldMapping     FieldMapping?   @relation(fields: [fieldMappingId], references: [id], onDelete: SetNull)
  userId           String?
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  action           String
  sourceSystemId   String
  sourceEntityName String
  sourceFieldName  String
  targetSystemId   String
  targetEntityName String
  targetFieldName  String
  transformType    String?
  createdAt        DateTime        @default(now())

  @@index([organisationId, createdAt])
  @@index([projectId, createdAt])
}

model CustomConnector {
  id               String   @id
  name             String
  vendor           String
  category         String
  description      String
  entityNames      String[] @default([])
  entities         Json
  connectionConfig Json
  createdByUserId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([createdAt])
  @@index([createdByUserId])
}

model LLMUserConfig {
  id              String   @id @default(uuid())
  userId          String   @unique
  mode            String   @default("default")
  provider        String?
  encryptedApiKey String?
  apiKeyHint      String?
  baseUrl         String?
  model           String?
  paused          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model LLMUsageEvent {
  id         String   @id @default(uuid())
  userId     String
  projectId  String?
  requestId  String?
  provider   String
  model      String?
  tokensUsed Int?
  durationMs Int
  success    Boolean
  error      String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}
