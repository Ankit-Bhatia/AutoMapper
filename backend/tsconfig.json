{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*.ts", "../packages/connectors/**/*.ts"],
  "exclude": [
    "dist",
    "src/__tests__/**",
    "../packages/connectors/**/*.js",
    "../packages/connectors/**/__tests__/**"
  ]
}
